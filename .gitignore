# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# env files — never commit secrets
.env
.env.local
.env.*.local

# database — contains encrypted private keys and live wallet data
*.db
*.db-shm
*.db-wal

# next.js
frontend/.next/
frontend/out/

# typescript build artifacts
dist/
build/
*.tsbuildinfo
frontend/next-env.d.ts

# test coverage
coverage/

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS
.DS_Store
*.pem

# claude local settings — may contain api keys or personal config
.claude/settings.local.json
**/settings.local.json

# vercel
.vercel

# skills zip archives
**/*.zip
